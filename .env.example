# ضع هذه المتغيرات في Railway Environment Variables

# ← مطلوب: توكن البوت من @BotFather
BOT_TOKEN=1234567890:ABCDefghIJKLmnopQRSTuvwxyz

# ← مطلوب: ID الأدمن (يمكن إضافة أكثر من واحد مفصولين بفاصلة)
ADMIN_IDS=123456789,987654321

# ← اختياري: الحد الأقصى لحجم الملف بالميجابايت (افتراضي: 50)
MAX_FILESIZE_MB=50

# ← اختياري: عدد التحميلات اليومية لكل مستخدم (افتراضي: 20)
DAILY_LIMIT=20

# ← اختياري: مسار قاعدة البيانات (افتراضي: mediabot.db)
DB_PATH=mediabot.db

# ← اختياري: مجلد الملفات المؤقتة
TMP_DIR=/tmp/mediabot
